  EN: [
    {
      "id": "accounting",
      "name": "MIXEL Accounting",
      "url": "acc.mixel.ch",
      "guide": "Accounting follows a complete 17-phase UAT plan imported from the official test document. Execute the phases in order and log all bugs with precise step/action evidence.",
      "categories": [
        {
          "idx": 1,
          "name": "A. Phase 1: Authentication and Login",
          "cases": [
            {
              "id": "ACC-001",
              "title": "Register – Create a New Account",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Navigate to https://acc.mixel.ch\n2. Click on "Kostenlos testen" or "Start Free".\n3. Enter a valid email address and create a password\n4. Complete all email verification steps\n5. Confirm the account was created",
              "expected": "Account created successfully. User is redirected to the app or an onboarding wizard.",
              "prio": "Medium"
            },
            {
              "id": "ACC-002",
              "title": "Login – Valid Credentials",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Navigate to https://acc.mixel.ch\n2. Click on "Anmelden".\n3. Enter a valid email and password\n4. Click on Sign In / Submit",
              "expected": "User is authenticated and redirected to the application dashboard.",
              "prio": "Medium"
            },
            {
              "id": "ACC-003",
              "title": "Login – Invalid Credentials",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Navigate tor Anmeldeseite\n2. Enter an incorrect password for a valid email\n3. Click on Anmelden",
              "expected": "Login is rejected. An error message is displayed (e.g. "Invalid credentials"). No access is granted.",
              "prio": "Medium"
            },
            {
              "id": "ACC-004",
              "title": "Login – Empty Field Validation",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Navigate tor Anmeldeseite\n2. Leave email and password fields empty\n3. Click on Anmelden",
              "expected": "Form validation is triggered. Required field errors are displayed. No login attempt is made.",
              "prio": "Medium"
            },
            {
              "id": "ACC-005",
              "title": "Password Reset Flow",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Click on der Anmeldeseite auf "Passwort vergessen".\n2. Enter a valid registered email address\n3. Click on "Link zum Zurücksetzen senden".\n4. Open the reset email and click the link\n5. Enter a new password and confirm it",
              "expected": "Password reset successfully. User can sign in with the new password.",
              "prio": "Medium"
            },
            {
              "id": "ACC-006",
              "title": "Sign Out",
              "where": "Auth > Login/Password Reset",
              "steps": "1. Sign in with valid credentials\n2. Navigate tom Benutzerprofil oder zum Einstellungsmenü\n3. Click on "Sign Out" oder "Sign Out".",
              "expected": "Session is terminated. User is redirected to the login page. The back button does not restore the authenticated session.",
              "prio": "Medium"
            }
          ]
        },
        {
          "idx": 2,
          "name": "B. Phase 2: Company and Initial Setup",
          "cases": [
            {
              "id": "ACC-007",
              "title": "Create First Company",
              "where": "Settings > Firmen-Setup",
              "steps": "1. Sign in to the app\n2. If prompted by an onboarding wizard, click on "Unternehmen erstellen".\n3. Enter the company name (e.g. "Acme Test GmbH")\n4. Enter company address, country and VAT ID\n5. Click on Speichern/Weiter",
              "expected": "Company is created. User lands on the company dashboard. The company name appears in the top navigation.",
              "prio": "Medium"
            },
            {
              "id": "ACC-008",
              "title": "Upload Company Logo",
              "where": "Settings > Firmen-Setup",
              "steps": "1. Navigate to den Unternehmenseinstellungen\n2. Find the logo upload field\n3. Upload a PNG or JPG image (max recommended size ~500 KB).\n4. Save the settings",
              "expected": "The logo is saved and displayed on the settings page. It should later appear on invoices and quotes.",
              "prio": "High"
            },
            {
              "id": "ACC-009",
              "title": "Configure Fiscal Year",
              "where": "Settings > Finance",
              "steps": "1. Click the button \"Financial\"\n2. Verify that the text \"IBAN\" is visible\n3. Verify that the text \"BIC\" is visible",
              "expected": "The Finance section shows fields for Fiscal Year Start, Default Currency, Bank Name and IBAN.",
              "prio": "High"
            },
            {
              "id": "ACC-010",
              "title": "Configure VAT Settings",
              "where": "Settings > Company Profile",
              "steps": "1. Verify that the text \"VAT Number\" is visible\n2. Verify that the text \"Company Name\" is visible",
              "expected": "Company Profile settings are visible with fields for VAT Number and Company Name.",
              "prio": "High"
            },
            {
              "id": "ACC-011",
              "title": "Set Invoice Numbering Format",
              "where": "Settings > Numbering",
              "steps": "1. Verify that a field with placeholder \"RE-\" is visible\n2. Verify that the text \"AN-\" is visible",
              "expected": "The Numbering section shows fields for Invoice (RE-), Quote (AN-) and Payment Term.",
              "prio": "High"
            },
            {
              "id": "ACC-012",
              "title": "Configure Default Payment Terms",
              "where": "Settings > Numbering",
              "steps": "1. Click the button \"Numbering\"\n2. Verify that the text \"Payment Term\" is visible",
              "expected": "The default payment terms field (Payment Term) is configurable.",
              "prio": "High"
            },
            {
              "id": "ACC-013",
              "title": "Select UI Language",
              "where": "Settings > My Profile",
              "steps": "1. Click the button \"My Profile\"\n2. Verify that the input field with placeholder \"Max Muster\" is visible\n3. Verify that the text \"Preferred Language\" is visible",
              "expected": "The profile form shows input fields for Display Name and Preferred Language.",
              "prio": "Medium"
            },
            {
              "id": "ACC-014",
              "title": "Set Email Sender Details",
              "where": "Settings > Email Settings",
              "steps": "1. Verify that a field with placeholder \"buchhaltung@firma.ch\" is visible\n2. Verify that a field with placeholder \"Max Muster\" is visible",
              "expected": "Email settings show fields for sender email (accounting@company.com) and sender name.",
              "prio": "High"
            }
          ]
        },
        {
          "idx": 3,
          "name": "C. Phase 3: Chart of Accounts",
          "cases": [
            {
